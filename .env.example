PORT=5000
CLIENT_ORIGIN=http://localhost:5173
NODE_ENV=development

# MySQL Database Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=brain_portal
MYSQL_CONNECTION_LIMIT=10

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_min_32_chars_recommended
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# Admin Configuration (Single Admin)
ADMIN_ONLY=true
ADMIN_EMAIL=admin@brain-ai.com

# VPN Configuration
VPN_ENABLED=true
VPN_DEFAULT_ENDPOINT=vpn-eu-1
VPN_PROTOCOL=wireguard
VPN_ENCRYPTION=256-bit-aes

# Upload Configuration
MAX_UPLOAD_SIZE=15728640
UPLOAD_DIRECTORY=./uploads

# Real-time Configuration (Socket.io)
SOCKET_IO_ENABLED=true
SOCKET_IO_CORS=true
SOCKET_IO_PORT=5000

# Payment Configuration
PAYMENT_GATEWAY=mock
PAYMENT_CURRENCY=EUR
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLIC_KEY=pk_test_your_key_here

# Email Configuration
EMAIL_SERVICE=smtp
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_email_password
EMAIL_FROM=noreply@brain-ai.com

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/brain.log

# Feature Flags
FEATURE_VPN=true
FEATURE_REALTIME=true
FEATURE_PAYMENTS=true
FEATURE_SMART_CARDS=true
FEATURE_ACTIVATIONS=true
FEATURE_ADMIN_PORTAL=true
FEATURE_CLIENT_PORTAL=true

# Security
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100
CORS_CREDENTIALS=true

# Analytics (Optional)
ANALYTICS_ENABLED=false
ANALYTICS_KEY=your_analytics_key

# Environment
ENVIRONMENT=development
DEBUG=false
